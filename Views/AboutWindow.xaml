<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PocketReader.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="About">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" RowDefinitions="*,Auto">

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" Padding="36,28" MaxWidth="420">
            <FontIcon Glyph="&#xE8F1;" FontSize="46" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="PocketReader" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0" />
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center" FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="Your read-it-later library — portable, private, offline."
                       TextAlignment="Center" TextWrapping="Wrap" FontSize="13" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />

            <TextBlock Text="Developer" FontSize="11" FontWeight="SemiBold" Margin="0,14,0,0" HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <HyperlinkButton NavigateUri="https://github.com/aungkokomm" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE774;" FontSize="14" />
                    <TextBlock Text="github.com/aungkokomm" />
                </StackPanel>
            </HyperlinkButton>

            <TextBlock x:Name="CopyrightText" HorizontalAlignment="Center" FontSize="12" Margin="0,12,0,0"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Padding="24,12" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Button Content="Close" Click="OnClose" HorizontalAlignment="Right" Style="{ThemeResource AccentButtonStyle}" MinWidth="92" />
        </Border>
    </Grid>
</Window>
