<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PocketReader.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          RowDefinitions="Auto,*,Auto">

        <Grid.Resources>
            <!-- Windows 11 "settings card" look -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,12" />
            </Style>
            <Style x:Key="Group" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="Margin" Value="2,10,0,2" />
            </Style>
            <Style x:Key="CardIcon" TargetType="FontIcon">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="Width" Value="28" />
                <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="CardTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="CardSub" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </Grid.Resources>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="24,20,24,6" Spacing="2">
            <TextBlock Text="Settings" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="Personalize PocketReader and manage your library." Style="{StaticResource CardSub}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Padding="24,4,24,12" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="6" MaxWidth="680" HorizontalAlignment="Stretch">

                <!-- Appearance -->
                <TextBlock Text="Appearance" Style="{StaticResource Group}" />
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE771;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="App theme" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="Follow Windows, or force light / dark." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <ComboBox Grid.Column="2" x:Name="ThemeCombo" MinWidth="150" VerticalAlignment="Center"
                                  SelectionChanged="OnThemeChanged">
                            <ComboBoxItem Content="System default" Tag="Default" />
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>
                    </Grid>
                </Border>
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE7C8;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Reading theme" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="Default page style when you open an article." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <ComboBox Grid.Column="2" x:Name="ReaderThemeCombo" MinWidth="150" VerticalAlignment="Center"
                                  SelectionChanged="OnReaderThemeChanged">
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Sepia" Tag="Sepia" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Offline downloads -->
                <TextBlock Text="Offline downloads" Style="{StaticResource Group}" />
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE896;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Articles per batch" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="How many articles each “Download offline” click caches." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <NumberBox Grid.Column="2" x:Name="BatchSizeBox" Width="130"
                                   Minimum="10" Maximum="5000" SmallChange="50" LargeChange="200"
                                   SpinButtonPlacementMode="Inline" ValueChanged="OnDownloadSettingChanged"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE945;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Parallel downloads" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="Higher is faster but heavier on your connection." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <NumberBox Grid.Column="2" x:Name="ConcurrencyBox" Width="130"
                                   Minimum="1" Maximum="24" SmallChange="1" LargeChange="2"
                                   SpinButtonPlacementMode="Inline" ValueChanged="OnDownloadSettingChanged"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Tags & library -->
                <TextBlock Text="Tags &amp; library" Style="{StaticResource Group}" />
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE8EC;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Manage tags" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="Rename, merge, delete, or create tags." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Open" Click="OnManageTags" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <FontIcon Grid.Row="0" Grid.Column="0" Glyph="&#xE74E;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Backup &amp; restore" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="Export your whole library to JSON, or import a backup." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Content="Export…" Click="OnExport" />
                            <Button Content="Import…" Click="OnImport" />
                        </StackPanel>
                        <TextBlock x:Name="BackupStatus" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Margin="6,6,0,0" Style="{StaticResource CardSub}" />
                    </Grid>
                </Border>

                <!-- Account -->
                <TextBlock Text="Account" Style="{StaticResource Group}" />
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE77B;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Raindrop.io" Style="{StaticResource CardTitle}" />
                            <TextBlock x:Name="AccountStatus" Text="Not connected" Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <Button Grid.Column="2" x:Name="LogoutButton" Content="Log out" Click="OnLogout" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Storage -->
                <TextBlock Text="Storage" Style="{StaticResource Group}" />
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="Data folder (portable)" Style="{StaticResource CardTitle}" />
                            <TextBlock x:Name="DataPath" Style="{StaticResource CardSub}" IsTextSelectionEnabled="True" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Open" Click="OnOpenFolder" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- About -->
                <TextBlock Text="About" Style="{StaticResource Group}" />
                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE946;" Style="{StaticResource CardIcon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,12,0">
                            <TextBlock Text="About PocketReader" Style="{StaticResource CardTitle}" />
                            <TextBlock Text="Version, developer, and project links." Style="{StaticResource CardSub}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="About" Click="OnAbout" VerticalAlignment="Center" />
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="VersionText" Grid.Column="0" VerticalAlignment="Center"
                           FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <Button Grid.Column="1" Content="Close" Click="OnClose" Style="{ThemeResource AccentButtonStyle}" MinWidth="92" />
            </Grid>
        </Border>
    </Grid>
</Window>
