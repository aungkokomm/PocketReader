<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PocketReader.TagManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PocketReader"
    Title="Tag Manager">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="24,20,24,8" Spacing="2">
            <TextBlock Text="Tag Manager" FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="Rename, merge, delete, or create tags. Tip: drag one tag onto another to merge."
                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" Background="Transparent"
                    HorizontalAlignment="Left" Margin="16,0,0,4" OverflowButtonVisibility="Collapsed">
            <AppBarButton Icon="Add" Label="New" Click="OnNew" />
            <AppBarButton Label="Rename" Click="OnRename">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8AC;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Merge" Click="OnMerge">
                <AppBarButton.Icon><FontIcon Glyph="&#xE71B;" /></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Icon="Delete" Label="Delete" Click="OnDelete" />
            <AppBarSeparator />
            <AppBarButton Icon="Refresh" Label="Refresh" Click="OnRefresh" />
        </CommandBar>

        <!-- Tag list -->
        <Border Grid.Row="2" Margin="24,4,24,8" CornerRadius="8" BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <ListView x:Name="TagList"
                      ItemsSource="{x:Bind Tags}"
                      SelectionMode="Extended"
                      CanDragItems="True" AllowDrop="True" CanReorderItems="False"
                      DragItemsStarting="OnTagDragStarting" DragOver="OnTagDragOver" Drop="OnTagDrop">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="12,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TagRow">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,8" ColumnSpacing="12">
                            <FontIcon Grid.Column="0" Glyph="&#xE8EC;" FontSize="14"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center"
                                       FontSize="14" TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="2" Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="10" Padding="9,2" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind CountText}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Content="Close" Click="OnClose" Style="{ThemeResource AccentButtonStyle}" MinWidth="92" />
            </Grid>
        </Border>
    </Grid>
</Window>
